DATAGEMS_POSTGRES_HOST=host_name
DATAGEMS_POSTGRES_PORT=5555
DATAGEMS_POSTGRES_USERNAME=username
DATAGEMS_POSTGRES_PASSWORD=password

DATAGEMS_TIMESCALE_DB_HOST=host_name
DATAGEMS_TIMESCALE_DB_PORT=5555
DATAGEMS_TIMESCALE_DB_USERNAME=username
DATAGEMS_TIMESCALE_DB_PASSWORD=password

# Root path prepended to distribution file paths (mount to S3)
DATA_ROOT_PATH=''
# Prefix prepended to RawDataPath connector dataset IDs on the Ray worker
MOUNT_POINT=''
# Directory where generated CDD profile JSON files are written
CDD_PROFILE_PATH=''

RAY_ADDRESS=ray://localhost:10001

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

ENABLE_AUTH=false

# LLM-based data quality error detection for tabular record sets (opt-in)
ENABLE_DATA_QUALITY=false
# LLM provider used for detection: "scayle" or "bedrock"
DATA_QUALITY_LLM_PROVIDER=scayle
# Optional model override (defaults: qwen3 for scayle, us.anthropic.claude-sonnet-4-6 for bedrock)
# DATA_QUALITY_LLM_MODEL=

# Required when DATA_QUALITY_LLM_PROVIDER=scayle
SCAYLE_BASE_URL=https://scayle-host/api
SCAYLE_USERNAME=username
SCAYLE_PASSWORD=password
SCAYLE_VERIFY_SSL=false

# Required when DATA_QUALITY_LLM_PROVIDER=bedrock
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
